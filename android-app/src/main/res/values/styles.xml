<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme -->
    <style name="Theme.ComposeApp" parent="android:Theme.Material.NoActionBar" />

    <!-- Custom splash screen theme: Light Mode -->
    <style name="Theme.AppStarting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.ComposeApp</item>
    </style>
</resources>